@model ClassroomDetailsViewModel

@{
    ViewData["Title"] = "Delete Classroom";
}

<div class="container mt-5">
    <h1 class="text-center">@ViewData["Title"]</h1>
    <hr/>

    @await Html.PartialAsync("~/Views/Admin/Classroom/_DetailsPartial.cshtml", Model)

    <div class="mt-5">
        <form asp-controller="Classroom" asp-action="DeleteConfirmed" method="post">
            <input type="hidden" name="schoolId" value="@Model.SchoolId"/>
            <input type="hidden" name="classroomId" value="@Model.Id"/>
            <button type="submit" class="btn btn-danger fw-bold">Delete</button>
        </form>
    </div>
</div>
