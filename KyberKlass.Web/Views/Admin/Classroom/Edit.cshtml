@model AddClassroomViewModel

@{
    ViewData["Title"] = "Edit Classroom";
}

<h1 class="text-center">@ViewData["Title"]</h1>
<hr/>

<form asp-controller="Classroom" asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Id"/>
    <input type="hidden" name="classroomId" value="@Model.Id"/>
    <input type="hidden" asp-for="SchoolId"/>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Classroom Name</label>
        <input asp-for="Name" class="form-control"/>
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TeacherId" class="form-label">Teacher</label>
        <select asp-for="TeacherId" class="form-select" asp-items="@(new SelectList(Model.UnassignedTeachers, "Id", "Name"))">
            <option value="">-- Select Teacher --</option>
        </select>
        <span asp-validation-for="TeacherId" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" asp-for="IsActive"/>
        <label class="form-check-label" for="@Model.IsActive">Is Active</label>
    </div>

    <button type="submit" class="btn btn-primary fw-bold">Save</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
