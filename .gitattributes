# Auto detect text files and normalize to LF
* text=auto

# C# files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf

# Config files
*.json text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Database/SQL
*.sql text eol=lf

# Docs
*.md text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.dll binary
